{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(systemctl status:*)",
      "Bash(journalctl:*)",
      "Bash(df:*)",
      "Bash(free:*)",
      "Bash(uptime)",
      "Bash(ps:*)",
      "mcp__postgres__query_data",
      "mcp__postgres__count_rows",
      "mcp__postgres__list_tables",
      "mcp__postgres__describe_table",
      "mcp__postgres__get_table_sample",
      "mcp__postgres__table_exists",
      "mcp__postgres__get_schema"
    ],
    "deny": [
      "Read(/home/<agent>/.ssh/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.env)",
      "Read(/etc/<agent>/secrets.env)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/secrets/**)",
      "Read(/home/<agent>/claude/.claude/projects/-home-<agent>-claude/memory/**)",
      "Write(/home/<agent>/.ssh/**)",
      "Write(/home/<agent>/claude/.claude/projects/-home-<agent>-claude/memory/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.env)",
      "Write(/etc/<agent>/secrets.env)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/secrets/**)",
      "Write(/etc/**)",
      "Write(/usr/lib/**)",
      "Write(/usr/share/**)",
      "Write(/var/log/**)",
      "Edit(/home/<agent>/.ssh/**)",
      "Edit(/home/<agent>/claude/.claude/projects/-home-<agent>-claude/memory/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.env)",
      "Edit(/etc/**)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -rf /)",
      "Bash(curl:* | bash:*)",
      "Bash(curl:* | sh:*)",
      "Bash(wget:* | bash:*)",
      "Bash(wget:* | sh:*)",
      "Bash(base64 -d:* | bash:*)",
      "Bash(base64 --decode:* | sh:*)",
      "Bash(nc -e:*)",
      "Bash(ncat -e:*)",
      "Bash(ssh:* -R:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chown -R:*)",
      "Bash(apt install:*)",
      "Bash(apt-get install:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(npm install -g:*)",
      "Bash(snap install:*)",
      "Bash(cargo install:*)",
      "Bash(brew install:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/sessionstart-hook.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/userprompt-hook.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/pretooluse-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/posttooluse-hook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/stop-hook.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/notification-hook.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/precompact-hook.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/<agent>/workspace/scripts/hooks/sessionend-hook.py"
          }
        ]
      }
    ]
  }
}
